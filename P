<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HBD SURPRISE! 🎂</title>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@300;600&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <style>
        /* พื้นฐานหน้าจอ */
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            background-color: #0a0a0a;
            font-family: 'Kanit', sans-serif;
            overflow: hidden;
            color: white;
        }

        /* เอฟเฟกต์แสง Background */
        .bg-glow {
            position: absolute;
            width: 400px;
            height: 400px;
            background: radial-gradient(circle, rgba(0, 255, 102, 0.2) 0%, rgba(0, 0, 0, 0) 70%);
            filter: blur(50px);
            z-index: 1;
            animation: pulse 4s infinite alternate;
        }

        @keyframes pulse {
            from { transform: scale(1); opacity: 0.5; }
            to { transform: scale(1.3); opacity: 0.8; }
        }

        /* Glassmorphism Card */
        .glass-card {
            position: relative;
            z-index: 10;
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(0, 255, 102, 0.3);
            border-radius: 30px;
            padding: 60px 40px;
            text-align: center;
            width: 85%;
            max-width: 420px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
            animation: slideUp 1s ease-out;
        }

        @keyframes slideUp {
            0% { opacity: 0; transform: translateY(50px); }
            100% { opacity: 1; transform: translateY(0); }
        }

        h1 {
            font-size: 2.8rem;
            color: #00ff66;
            text-shadow: 0 0 20px rgba(0, 255, 102, 0.5);
            margin-bottom: 10px;
            letter-spacing: 2px;
        }

        p {
            color: #ccc;
            font-size: 1.1rem;
            line-height: 1.8;
            margin-bottom: 40px;
        }

        /* ปุ่มกด */
        .btn-surprise {
            display: inline-block;
            padding: 18px 40px;
            background: #00ff66;
            color: #000;
            border-radius: 50px;
            font-size: 1.2rem;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.3s ease;
            box-shadow: 0 10px 20px rgba(0, 255, 102, 0.3);
            cursor: pointer;
        }

        .btn-surprise:hover {
            transform: scale(1.05) translateY(-5px);
            box-shadow: 0 15px 30px rgba(0, 255, 102, 0.5);
            background: #fff;
        }

        /* ประดับตกแต่ง */
        .decoration {
            position: absolute;
            bottom: 30px;
            font-family: 'Courier New', Courier, monospace;
            color: rgba(0, 255, 102, 0.4);
            font-size: 0.85rem;
            letter-spacing: 1px;
        }
    </style>
</head>
<body>

    <div class="bg-glow"></div>

    <div class="glass-card">
        <h1>HBD TO YOU</h1>
        <p>Level Up ไปอีกปีแล้วนะ!<br>ขอให้ระบบชีวิตรันสมูท ไม่มีสะดุด<br>มีความสุขและประสบความสำเร็จในทุกโปรเจกต์นะ 🚀</p>
        
        <a href="https://www.tiktok.com" target="_blank" class="btn-surprise" onclick="celebrate()">
            CLICK FOR SURPRISE
        </a>
    </div>

    <div class="decoration">STATUS: SYSTEM_READY // HB_CORE_V3.0</div>

    <script>
        // ฟังก์ชันยิงพลุเมื่อเปิดหน้าเว็บ
        window.onload = function() {
            var duration = 3 * 1000;
            var end = Date.now() + duration;

            (function frame() {
                confetti({
                    particleCount: 3,
                    angle: 60,
                    spread: 55,
                    origin: { x: 0 },
                    colors: ['#00ff66', '#ffffff']
                });
                confetti({
                    particleCount: 3,
                    angle: 120,
                    spread: 55,
                    origin: { x: 1 },
                    colors: ['#00ff66', '#ffffff']
                });

                if (Date.now() < end) {
                    requestAnimationFrame(frame);
                }
            }());
        };

        // ฟังก์ชันยิงพลุเพิ่มเมื่อกดปุ่ม
        function celebrate() {
            confetti({
                particleCount: 150,
                spread: 70,
                origin: { y: 0.6 },
                colors: ['#00ff66', '#ffffff', '#222222']
            });
        }
    </script>
</body>
</html>
